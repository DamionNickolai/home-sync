# Copy to project root:  Copy-Item maintenance/.env.example .env
# NEVER commit .env — it is gitignored.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
ENCRYPTION_KEY=your-32-byte-base64-encoded-key

# --- Postgres (maintenance scripts: audit_schema_parity, apply_schema_parity) ---
# Password from Supabase → Connect → Direct connection (NOT the API keys above).

# Recommended: plain password (handles special characters automatically)
SUPABASE_DB_PASSWORD=your-database-password-here

# Alternative: full connection string (URL-encode special chars in password)
# SUPABASE_DB_URL=postgresql://postgres:your-database-password@db.your-project-ref.supabase.co:5432/postgres
